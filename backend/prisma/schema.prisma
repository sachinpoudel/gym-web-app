generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  ACTIVE
  EXPIRED
  FROZEN
}

enum MemberPlan {
  BASIC
  PRO
  ELITE
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  FAILED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

enum UserRole {
  ADMIN
  MEMBER
  TRAINER
  FRONT_DESK
}

