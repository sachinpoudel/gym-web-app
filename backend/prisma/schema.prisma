model Payment {
  id        String        @id @default(uuid())
  memberId  String
  member    Member        @relation(fields: [memberId], references: [id])
  amount    Float
  plan      MemberPlan
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod @default(CASH)
  paidAt    DateTime?
  dueDate   DateTime
  createdAt DateTime      @default(now())

  @@index([status])
  @@index([paidAt])
  @@index([dueDate])
  @@index([memberId])
}

